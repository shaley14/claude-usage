{
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/common/v2.0",
          "clientIdSettingName": "AAD_CLIENT_ID",
          "clientSecretSettingName": "AAD_CLIENT_SECRET"
        }
      }
    }
  },
  "routes": [
    { "route": "/.auth/login/aad", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/login", "rewrite": "/.auth/login/aad", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/unauthorized.html", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/*", "allowedRoles": ["viewer"] }
  ],
  "responseOverrides": {
    "401": { "rewrite": "/unauthorized.html", "statusCode": 403 }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/unauthorized.html", "/.auth/*"]
  }
}